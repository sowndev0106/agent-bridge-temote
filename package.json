{
  "name": "agent-remote-control",
  "version": "0.1.3",
  "description": "Launch AI coding agents and surface their remote links in a browser UI",
  "type": "module",
  "license": "MIT",
  "author": "sowndev <sowndev0106@gmail.com>",
  "homepage": "https://github.com/sowndev0106/agent-bridge-temote#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sowndev0106/agent-bridge-temote.git"
  },
  "bugs": {
    "url": "https://github.com/sowndev0106/agent-bridge-temote/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude",
    "cli",
    "remote",
    "terminal",
    "web-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/server/index.js",
  "bin": {
    "arc": "./dist/bin/arc.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node --env-file-if-exists .env node_modules/tsx/dist/cli.mjs watch src/server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsup",
    "build:web": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:responsive": "playwright test tests/e2e/responsive-ui.spec.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/static": "^7.0.4",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "commander": "^12.1.0",
    "dockview": "^6.6.1",
    "fastify": "^4.28.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "open": "^10.1.0",
    "pino": "^9.3.2",
    "react-complex-tree": "^2.6.1",
    "react-resizable-panels": "^4.11.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.11",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.2",
    "vitest": "^1.6.0",
    "zustand": "^4.5.2"
  }
}
