# RemoteBridge env-var overrides (RB_* prefix).
# These take HIGHEST priority — they override ~/.remotebridge/config.json.
# Useful in dev mode or CI without touching the config file.
#
# Copy this file to .env and fill in the values you need.
# tsx/vite will load .env automatically in dev mode.

NODE_ENV=development

# --- Required for dev when host=0.0.0.0 (default) ---
# Any non-empty string works as a dev password (stored plaintext here, bcrypt in prod config).
RB_PASSWORD=devpassword

# Any random string works as a session signing secret in dev.
RB_SESSION_SECRET=dev-secret-change-me-in-production

# --- Optional overrides ---
# RB_PORT=4096
# RB_HOST=127.0.0.1
# RB_SESSION_TTL=86400
# RB_LOG_LEVEL=debug
# RB_LINK_EXTRACT_TIMEOUT=30
# RB_MAX_CONCURRENT_SESSIONS=10
# RB_KEEP_SESSION_LOGS_LINES=500
